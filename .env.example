# Optional OpenAI fallback (disabled by default; local model is used first)
OPENAI_API_KEY=
USE_OPENAI_VISION=false
LOCAL_VISION_MODEL=openai/clip-vit-base-patch32

# Magrabi ecom endpoint for DB URL lookup by variant attributes
ECOM_ATTRIBUTE_MATCH_URL=http://localhost:8000/api/variant-match/

# Auth options (priority: ECOM_API_TOKEN -> SALEOR_API_TOKEN -> user/password token generation)
ECOM_API_TOKEN=
ECOM_API_USERNAME=
ECOM_API_PASSWORD=
SALEOR_GRAPHQL_URL=http://localhost:8000/graphql/
SALEOR_API_TOKEN=
SALEOR_USER_EMAIL=
SALEOR_USER_PASSWORD=
# Backward-compatible keys if you prefer lower case
saleor_user_email=
saleor_user_password=
SALEOR_CHANNEL_SLUG=default-channel
